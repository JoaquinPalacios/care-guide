generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ClinicMembershipRole {
  ADMIN
  STAFF
}

model Clinic {
  id                 String              @id @default(cuid())
  name               String
  memberships        ClinicMembership[]
  procedureTemplates ProcedureTemplate[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String             @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  memberships   ClinicMembership[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model ClinicMembership {
  id        String               @id @default(cuid())
  clinicId  String
  userId    String
  role      ClinicMembershipRole
  clinic    Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([clinicId, userId])
  @@index([userId])
  @@index([clinicId, role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model ProcedureTemplate {
  id                  String                                @id @default(cuid())
  clinicId            String
  name                String
  slug                String
  isActive            Boolean                               @default(true)
  clinic              Clinic                                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  stageTemplates      ProcedureStageTemplate[]
  selectedAreaOptions ProcedureTemplateSelectedAreaOption[]
  createdAt           DateTime                              @default(now())
  updatedAt           DateTime                              @updatedAt

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
}

model ProcedureStageTemplate {
  id                  String            @id @default(cuid())
  procedureTemplateId String
  stageOrder          Int
  title               String
  calmCopy            String
  patientCopy         String
  detailedCopy        String
  illustrationUrl     String?
  defaultDurationHint String?
  procedureTemplate   ProcedureTemplate @relation(fields: [procedureTemplateId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([procedureTemplateId, stageOrder])
  @@index([procedureTemplateId])
}

model ProcedureTemplateSelectedAreaOption {
  id                  String            @id @default(cuid())
  procedureTemplateId String
  key                 String
  label               String
  sortOrder           Int
  isActive            Boolean           @default(true)
  procedureTemplate   ProcedureTemplate @relation(fields: [procedureTemplateId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([procedureTemplateId, key])
  @@unique([procedureTemplateId, sortOrder])
  @@index([procedureTemplateId, isActive])
}
