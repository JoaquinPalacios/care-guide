# Matches the local Postgres container in compose.yaml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/care_guide?schema=public"
AUTH_SECRET="replace-with-a-long-random-string"

# Supabase Realtime — optional in local dev. When these are unset the
# realtime publisher falls back to a no-op and the patient display
# subscriber becomes inert. Stage transitions still commit to the
# database and refreshing /display/[token] shows the latest persisted
# stage; only live updates are disabled.
#
# NEXT_PUBLIC_* vars are bundled into the patient client JavaScript.
# The service role key is server-only and must NEVER be prefixed with
# NEXT_PUBLIC_ — it authorizes the server-side broadcast publisher.
# Database Password for Supabase Postgres
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_PASSWORD="
